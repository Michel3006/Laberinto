# .env.example — copiar a .env para desarrollo local. NUNCA subir .env a Git.

PORT=3000
NODE_ENV=development

# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=cambia_esto_por_una_clave_aleatoria_de_al_menos_32_caracteres

# Dominio permitido en producción (tu URL de Render)
ALLOWED_ORIGIN=http://localhost:3000

# Límites del servidor
MAX_ROOMS=100
MAX_PLAYERS_PER_IP=5
TURN_TIMEOUT_MS=60000
